#!/usr/bin/env bash
# audit-repo-beads - Explore all branches in recent repos and report beads issues
#
# For the N most recently committed repos in ~/src, checks every branch
# (using temporary worktrees when the working tree is dirty) for a .beads/
# directory and reports beads issues found on each branch.
#
# Usage: audit-repo-beads [N]        (default: 10)
#        audit-repo-beads --repo <path>  (audit a single repo)

set -euo pipefail

SRC_DIR="${HOME}/src"
DEFAULT_COUNT=10
TMPDIR_BASE="/tmp/audit-repo-beads-$$"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
RESET='\033[0m'

cleanup() {
    if [[ -d "$TMPDIR_BASE" ]]; then
        # Remove any worktrees we created
        for wt_dir in "$TMPDIR_BASE"/wt-*; do
            [[ -d "$wt_dir" ]] || continue
            local repo_git
            repo_git=$(git -C "$wt_dir" rev-parse --git-common-dir 2>/dev/null || true)
            if [[ -n "$repo_git" ]]; then
                git -C "$repo_git/.." worktree remove --force "$wt_dir" 2>/dev/null || rm -rf "$wt_dir"
            else
                rm -rf "$wt_dir"
            fi
        done
        rm -rf "$TMPDIR_BASE"
    fi
}
trap cleanup EXIT

mkdir -p "$TMPDIR_BASE"

# --- Helpers ---

# Get the N most recently committed repos under $SRC_DIR
get_recent_repos() {
    local count="$1"
    local repos=()
    for d in "$SRC_DIR"/*/; do
        [[ -d "$d/.git" ]] || continue
        local date
        date=$(git -C "$d" log -1 --format='%aI' 2>/dev/null) || continue
        [[ -n "$date" ]] && repos+=("$date $d")
    done
    printf '%s\n' "${repos[@]}" | sort -r | head -n "$count" | awk '{print $2}'
}

# Check if a branch's tree contains .beads/ using git ls-tree (no checkout needed)
branch_has_beads_tree() {
    local repo_dir="$1"
    local branch="$2"
    local result
    result=$(git -C "$repo_dir" ls-tree --name-only "$branch" .beads/ 2>/dev/null)
    [[ -n "$result" ]]
}

# Try to get beads issue count from a branch using a temp worktree
get_beads_issues_via_worktree() {
    local repo_dir="$1"
    local branch="$2"
    local wt_name
    wt_name="wt-$(basename "$repo_dir")-$(echo "$branch" | tr '/' '-')"
    local wt_path="$TMPDIR_BASE/$wt_name"

    if [[ -d "$wt_path" ]]; then
        rm -rf "$wt_path"
    fi

    git -C "$repo_dir" worktree add "$wt_path" "$branch" --detach 2>/dev/null || return 1

    local issues
    issues=$(cd "$wt_path" && bd list --limit 0 2>/dev/null) || issues=""

    git -C "$repo_dir" worktree remove --force "$wt_path" 2>/dev/null || true

    echo "$issues"
}

# Get beads issues for the current working directory
get_beads_issues_current() {
    local repo_dir="$1"
    cd "$repo_dir"
    bd list --limit 0 2>/dev/null || bd list --limit 0 --allow-stale 2>/dev/null || echo ""
}

# Filter to just issue lines (lines starting with bd status symbols)
filter_issue_lines() {
    echo "$1" | grep -E '^[○◐●✓✗]' 2>/dev/null || true
}

# Count issue lines
count_issues() {
    local lines
    lines=$(filter_issue_lines "$1")
    if [[ -z "$lines" ]]; then echo "0"; else echo "$lines" | wc -l | tr -d ' '; fi
}

count_open() {
    local lines
    lines=$(echo "$1" | grep -E '^[○◐]' 2>/dev/null || true)
    if [[ -z "$lines" ]]; then echo "0"; else echo "$lines" | wc -l | tr -d ' '; fi
}

count_in_progress() {
    local lines
    lines=$(echo "$1" | grep -E '^◐' 2>/dev/null || true)
    if [[ -z "$lines" ]]; then echo "0"; else echo "$lines" | wc -l | tr -d ' '; fi
}

count_closed() {
    local lines
    lines=$(echo "$1" | grep -E '^[✓]' 2>/dev/null || true)
    if [[ -z "$lines" ]]; then echo "0"; else echo "$lines" | wc -l | tr -d ' '; fi
}

# --- Main audit for a single repo ---

audit_repo() {
    local repo_dir="$1"
    repo_dir="${repo_dir%/}"
    local repo_name
    repo_name=$(basename "$repo_dir")

    echo -e "\n${BOLD}${BLUE}═══════════════════════════════════════════════════════${RESET}"
    echo -e "${BOLD}${BLUE} Repository: ${repo_name}${RESET}"
    echo -e "${BOLD}${BLUE}═══════════════════════════════════════════════════════${RESET}"

    # Git status
    local status
    status=$(git -C "$repo_dir" status -sb 2>/dev/null)
    local current_branch
    current_branch=$(git -C "$repo_dir" symbolic-ref --short HEAD 2>/dev/null || echo "(detached)")
    echo -e "  ${BOLD}Branch:${RESET} $current_branch"
    local dirty=""
    if echo "$status" | grep -qE '^ ?[MADRCU?!]'; then
        dirty="yes"
        echo -e "  ${YELLOW}Working tree has uncommitted changes${RESET}"
    else
        echo -e "  ${GREEN}Working tree clean${RESET}"
    fi

    # List all branches (local + remote, deduplicated)
    local all_branches=()
    local branch_line
    while IFS= read -r branch_line; do
        branch_line=$(echo "$branch_line" | sed 's/^[* ] //' | xargs)
        # Skip HEAD pointers
        [[ "$branch_line" == *"HEAD"* ]] && continue
        [[ -z "$branch_line" ]] && continue
        all_branches+=("$branch_line")
    done < <(git -C "$repo_dir" branch -a --no-color 2>/dev/null)

    echo -e "  ${BOLD}Total branches:${RESET} ${#all_branches[@]}"

    # Check which branches have .beads/ in their tree
    local branches_with_beads=()
    local branches_without_beads=()

    for branch in "${all_branches[@]}"; do
        if branch_has_beads_tree "$repo_dir" "$branch"; then
            branches_with_beads+=("$branch")
        else
            branches_without_beads+=("$branch")
        fi
    done

    echo -e "  ${BOLD}Branches with .beads/:${RESET} ${#branches_with_beads[@]}"

    if [[ ${#branches_with_beads[@]} -eq 0 ]]; then
        # Also check the filesystem directly (beads might not be committed)
        if [[ -d "$repo_dir/.beads" ]]; then
            echo -e "  ${YELLOW}Note: .beads/ exists on disk but not in git tree${RESET}"
            echo -e "\n  ${BOLD}Issues (current branch):${RESET}"
            local issues
            issues=$(get_beads_issues_current "$repo_dir")
            if [[ -n "$issues" ]]; then
                local total open closed in_progress
                total=$(count_issues "$issues")
                open=$(count_open "$issues")
                in_progress=$(count_in_progress "$issues")
                closed=$(count_closed "$issues")
                echo "    Total: $total | Open: $open | In-progress: $in_progress | Closed: $closed"
                filter_issue_lines "$issues" | head -20 | sed 's/^/    /'
                if [[ $total -gt 20 ]]; then
                    echo -e "    ${YELLOW}... and $((total - 20)) more${RESET}"
                fi
            else
                echo -e "    ${YELLOW}(no issues or bd not available)${RESET}"
            fi
        else
            echo -e "  ${YELLOW}No beads tracking in this repo${RESET}"
        fi
        return
    fi

    # Get issues from the current branch first
    echo -e "\n  ${BOLD}Issues (current branch: $current_branch):${RESET}"
    local current_issues
    current_issues=$(get_beads_issues_current "$repo_dir")
    if [[ -n "$current_issues" ]]; then
        local total open closed in_progress
        total=$(count_issues "$current_issues")
        open=$(count_open "$current_issues")
        in_progress=$(count_in_progress "$current_issues")
        closed=$(count_closed "$current_issues")
        echo "    Total: $total | Open: $open | In-progress: $in_progress | Closed: $closed"
        filter_issue_lines "$current_issues" | head -20 | sed 's/^/    /'
        if [[ $total -gt 20 ]]; then
            echo -e "    ${YELLOW}... and $((total - 20)) more${RESET}"
        fi
    else
        echo -e "    ${YELLOW}(bd list returned nothing)${RESET}"
    fi

    # Check if other branches have different issue sets
    # Use git show to compare issues.jsonl across branches
    local current_hash
    current_hash=$(git -C "$repo_dir" rev-parse "$current_branch:.beads/issues.jsonl" 2>/dev/null || echo "none")

    local differing_branches=()
    for branch in "${branches_with_beads[@]}"; do
        # Skip the current branch
        local clean_branch="${branch#remotes/}"
        [[ "$branch" == "$current_branch" ]] && continue

        local branch_hash
        branch_hash=$(git -C "$repo_dir" rev-parse "$branch:.beads/issues.jsonl" 2>/dev/null || echo "none")

        if [[ "$branch_hash" != "$current_hash" ]]; then
            differing_branches+=("$branch")
        fi
    done

    if [[ ${#differing_branches[@]} -gt 0 ]]; then
        echo -e "\n  ${BOLD}Branches with different issue sets:${RESET}"
        for branch in "${differing_branches[@]}"; do
            local line_count
            line_count=$(git -C "$repo_dir" show "$branch:.beads/issues.jsonl" 2>/dev/null | wc -l)
            echo -e "    - $branch ($line_count issue lines)"
        done
    elif [[ ${#branches_with_beads[@]} -gt 1 ]]; then
        echo -e "\n  ${GREEN}All ${#branches_with_beads[@]} branches with beads share the same issue set${RESET}"
    fi

    # List branches without beads (if any have beads, this context is useful)
    if [[ ${#branches_without_beads[@]} -gt 0 && ${#branches_without_beads[@]} -le 10 ]]; then
        echo -e "\n  Branches without .beads/: ${branches_without_beads[*]}"
    elif [[ ${#branches_without_beads[@]} -gt 10 ]]; then
        echo -e "\n  ${#branches_without_beads[@]} branches without .beads/"
    fi
}

