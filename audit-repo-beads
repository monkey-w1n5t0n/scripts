.hbar .bar { height: 20px; border-radius: 3px; transition: width .3s; min-width: 2px;
  display: flex; align-items: center; padding-left: 6px; font-size: 11px; font-weight: 600; color: white; }
.hbar .count { margin-left: 8px; font-size: 12px; color: var(--fg3); flex-shrink: 0; }
@media (max-width: 900px) {
  .sidebar { display: none; }
  .main { margin-left: 0; padding: 16px; }
  .chart-section { grid-template-columns: 1fr; }
