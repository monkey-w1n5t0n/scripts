.issue-table-wrap { overflow-x: auto; }
table.issues { width: 100%%; border-collapse: collapse; font-size: 13px; }
table.issues th { text-align: left; padding: 10px 12px; border-bottom: 2px solid var(--bg3);
  color: var(--fg3); font-weight: 600; cursor: pointer; user-select: none;
  white-space: nowrap; font-size: 11px; text-transform: uppercase; letter-spacing: .5px; }
table.issues th:hover { color: var(--fg); }
table.issues th .sort-arrow { margin-left: 4px; opacity: .4; }
table.issues th.sorted .sort-arrow { opacity: 1; color: var(--accent2); }
table.issues td { padding: 10px 12px; border-bottom: 1px solid var(--bg3); vertical-align: top; }
table.issues tr:hover { background: rgba(99,102,241,.06); }
table.issues .title { max-width: 400px; }
table.issues .deps { font-size: 11px; color: var(--fg3); }
.filters { display: flex; gap: 12px; margin-bottom: 16px; flex-wrap: wrap; align-items: center; }
.search { background: var(--bg2); border: 1px solid var(--bg3); border-radius: var(--radius);
  padding: 8px 14px; color: var(--fg); font-size: 14px; width: 260px; outline: none; }
.search:focus { border-color: var(--accent); }
.filter-group { display: flex; gap: 4px; flex-wrap: wrap; }
.filter-btn { background: var(--bg2); border: 1px solid var(--bg3); border-radius: 4px;
  padding: 5px 10px; color: var(--fg2); font-size: 12px; cursor: pointer; transition: all .1s; }
.filter-btn:hover { border-color: var(--fg3); color: var(--fg); }
.filter-btn.active { background: var(--accent); border-color: var(--accent); color: white; }
.section-header { display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 18px; }
.section-header h2 { font-size: 22px; font-weight: 600; }
.back-btn { background: var(--bg2); border: 1px solid var(--bg3); border-radius: var(--radius);
  padding: 7px 16px; color: var(--fg2); cursor: pointer; font-size: 13px; transition: all .1s; }
.back-btn:hover { border-color: var(--accent); color: var(--fg); }
.chart-section { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 20px; }
.chart-card { background: var(--bg2); border-radius: var(--radius); padding: 18px;
  border: 1px solid var(--bg3); }
.chart-card h3 { font-size: 13px; color: var(--fg3); margin-bottom: 14px; text-transform: uppercase;
  letter-spacing: .5px; font-weight: 600; }
.hbar { display: flex; align-items: center; margin: 6px 0; }
