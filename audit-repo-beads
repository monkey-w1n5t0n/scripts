.badge-type { display: inline-block; padding: 2px 8px; border-radius: 4px;
  font-size: 11px; font-weight: 500; border: 1px solid; }
.badge-epic { color: var(--epic); border-color: var(--epic); }
.badge-task { color: var(--p2); border-color: var(--p2); }
