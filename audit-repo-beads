# --- Entry point ---

main() {
    local count="$DEFAULT_COUNT"
    local single_repo=""
    local web_mode=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --repo)
                single_repo="$2"
                shift 2
                ;;
            --web|--html)
                web_mode=true
                shift
                ;;
            --help|-h)
                echo "Usage: audit-repo-beads [N]"
                echo "       audit-repo-beads --repo <path>"
                echo "       audit-repo-beads --web [N]"
                echo ""
                echo "Audits the N most recently committed repos in ~/src for beads issues"
                echo "across all branches. Uses git ls-tree to check branches without checkout"
                echo "and temporary worktrees when needed."
                echo ""
                echo "Options:"
                echo "  --web, --html    Generate interactive HTML report and open in browser"
                echo "  --repo <path>    Audit a single repo"
                echo "  N                Number of repos to audit (default: 10)"
                exit 0
                ;;
            [0-9]*)
                count="$1"
                shift
                ;;
            *)
                echo "Unknown argument: $1" >&2
                exit 1
                ;;
        esac
    done

    # Collect repo list
    local repo_list=()
    if [[ -n "$single_repo" ]]; then
        repo_list+=("$single_repo")
    else
        while IFS= read -r repo; do
            [[ -z "$repo" ]] && continue
            repo_list+=("${repo%/}")
        done < <(get_recent_repos "$count")
    fi

    if [[ "$web_mode" == "true" ]]; then
        generate_web_report "${repo_list[@]}"
    else
        if [[ -n "$single_repo" ]]; then
            audit_repo "$single_repo"
        else
            echo -e "${BOLD}Auditing top $count most recently committed repos in $SRC_DIR${RESET}"
            echo -e "Date: $(date -Iseconds)\n"
            for repo in "${repo_list[@]}"; do
                audit_repo "$repo"
            done
        fi
        echo -e "\n${BOLD}${GREEN}Audit complete.${RESET}"
    fi
}

main "$@"
