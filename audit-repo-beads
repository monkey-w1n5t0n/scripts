<body>
<div class="app">
  <nav class="sidebar">
    <h1><span>&#x25C9;</span> Beads Audit</h1>
    <div class="nav-item active" onclick="showDashboard()" id="nav-dashboard">Dashboard</div>
    <div class="nav-section">Repositories</div>
    <div id="nav-repos"></div>
  </nav>
  <main class="main" id="main-content"></main>
</div>
<script>
const DATA = %s;
const P_COLORS = {0:'#ef4444',1:'#f97316',2:'#3b82f6',3:'#6b7280',4:'#475569'};
const T_COLORS = {epic:'#a855f7',task:'#3b82f6',bug:'#ef4444',feature:'#22c55e'};
let currentSort = {col:null, asc:true};
let activeFilters = {priority:null, type:null, status:null};
let searchQuery = '';

function priorityBadge(p) { return '<span class="badge-p'+p+'">P'+p+'</span>'; }
function typeBadge(t) {
  const cls = T_COLORS[t] ? t : 'task';
  return '<span class="badge-type badge-'+cls+'">'+(t||'task')+'</span>';
}
function statusIcon(s) {
  if (s==='closed') return '<span class="status-icon" title="closed">\\u2713</span>';
  if (s==='in_progress') return '<span class="status-icon" title="in progress">\\u25D0</span>';
  return '<span class="status-icon" title="open">\\u25CB</span>';
}
function pbar(issues) {
  const counts = {};
  issues.forEach(i => { const p=i.priority??2; counts[p]=(counts[p]||0)+1; });
  const total = issues.length||1;
  let h = '<div class="pbar">';
  [0,1,2,3,4].forEach(p => {
    if (counts[p]) {
      const pct=counts[p]/total*100;
      h += '<div style="width:'+pct+'%%;background:'+P_COLORS[p]+'" title="P'+p+': '+counts[p]+'">'+(counts[p]>0&&pct>8?counts[p]:'')+'</div>';
    }
  });
  return h+'</div>';
}
function setActive(id) {
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  const el=document.getElementById(id); if(el) el.classList.add('active');
}

function showDashboard() {
  setActive('nav-dashboard');
  const main=document.getElementById('main-content');
  const all=DATA.repos.flatMap(r=>r.issues);
  const openC=all.filter(i=>i.status!=='closed').length;
  const wipC=all.filter(i=>i.status==='in_progress').length;
  const closedC=all.filter(i=>i.status==='closed').length;
  const withB=DATA.repos.filter(r=>r.issues.length>0).length;
  main.innerHTML = '<div class="section-header"><h2>Dashboard</h2><span style="color:var(--fg3);font-size:13px">Generated '+new Date(DATA.generated_at).toLocaleString()+'</span></div>'+
    '<div class="stats">'+
    '<div class="stat-card"><div class="label">Repositories</div><div class="value">'+DATA.repos.length+'</div><div class="sub">'+withB+' with beads</div></div>'+
    '<div class="stat-card"><div class="label">Total Issues</div><div class="value">'+all.length+'</div><div class="sub">'+openC+' open, '+wipC+' in progress</div></div>'+
    '<div class="stat-card"><div class="label">Open</div><div class="value" style="color:var(--open)">'+openC+'</div></div>'+
    '<div class="stat-card"><div class="label">In Progress</div><div class="value" style="color:var(--wip)">'+wipC+'</div></div>'+
    '<div class="stat-card"><div class="label">Closed</div><div class="value" style="color:var(--closed)">'+closedC+'</div></div></div>'+
    '<h3 style="margin-bottom:14px;font-size:14px;color:var(--fg3);text-transform:uppercase;letter-spacing:.5px">Priority Distribution</h3>'+
    '<div id="prio-chart" style="margin-bottom:28px"></div>'+
    '<h3 style="margin-bottom:14px;font-size:14px;color:var(--fg3);text-transform:uppercase;letter-spacing:.5px">Repositories</h3>'+
    '<div class="repo-grid" id="repo-grid"></div>';
  const ch=document.getElementById('prio-chart');
  DATA.repos.filter(r=>r.issues.length>0).sort((a,b)=>b.issues.length-a.issues.length).forEach(r=>{
    const row=document.createElement('div'); row.className='hbar'; row.style.cursor='pointer';
    row.onclick=()=>showRepo(r.name);
    row.innerHTML='<div class="label">'+r.name+'</div><div style="flex:1">'+pbar(r.issues)+'</div><div class="count">'+r.issues.length+'</div>';
    ch.appendChild(row);
  });
  const grid=document.getElementById('repo-grid');
  DATA.repos.forEach(r=>{
    const card=document.createElement('div'); card.className='repo-card';
    card.onclick=()=>showRepo(r.name);
    if(r.issues.length===0){
      card.innerHTML='<h3>'+r.name+'</h3><div class="meta"><span>\\u{1f33f} '+r.current_branch+'</span><span>'+r.branch_count+' branches</span>'+(r.dirty?'<span style="color:var(--open)">\\u25cf dirty</span>':'')+'</div><div class="no-beads">No beads tracking</div>';
    } else {
      card.innerHTML='<h3>'+r.name+' <span style="font-size:13px;color:var(--fg3);font-weight:400">'+r.issues.length+' issues</span></h3><div class="meta"><span>\\u{1f33f} '+r.current_branch+'</span><span>'+r.branch_count+' branches</span>'+(r.dirty?'<span style="color:var(--open)">\\u25cf dirty</span>':'')+'</div><div class="pbar-wrap">'+pbar(r.issues)+'</div><div style="font-size:12px;color:var(--fg3);margin-top:8px">'+r.issues.filter(i=>i.status!=='closed').length+' open \\u00b7 '+r.issues.filter(i=>i.status==='in_progress').length+' in progress \\u00b7 '+r.issues.filter(i=>i.status==='closed').length+' closed</div>';
    }
    grid.appendChild(card);
  });
}

function showRepo(name) {
  setActive('nav-repo-'+name);
  const repo=DATA.repos.find(r=>r.name===name); if(!repo) return;
  activeFilters={priority:null,type:null,status:null}; searchQuery=''; currentSort={col:null,asc:true};
  const main=document.getElementById('main-content');
  const labels={}; repo.issues.forEach(i=>(i.labels||[]).forEach(l=>{labels[l]=(labels[l]||0)+1}));
  const topL=Object.entries(labels).sort((a,b)=>b[1]-a[1]).slice(0,20);
  let ih='<div class="section-header"><h2>'+repo.name+'</h2><button class="back-btn" onclick="showDashboard()">\\u2190 Dashboard</button></div>'+
    '<div class="stats">'+
    '<div class="stat-card"><div class="label">Branch</div><div class="value" style="font-size:16px">'+repo.current_branch+'</div><div class="sub">'+(repo.dirty?'Uncommitted changes':'Clean')+'</div></div>'+
    '<div class="stat-card"><div class="label">Branches</div><div class="value">'+repo.branch_count+'</div><div class="sub">'+repo.branches_with_beads+' with beads</div></div>'+
    '<div class="stat-card"><div class="label">Issues</div><div class="value">'+repo.issues.length+'</div></div>'+
    '<div class="stat-card"><div class="label">Open</div><div class="value" style="color:var(--open)">'+repo.issues.filter(i=>i.status!=='closed').length+'</div></div>'+
    '<div class="stat-card"><div class="label">In Progress</div><div class="value" style="color:var(--wip)">'+repo.issues.filter(i=>i.status==='in_progress').length+'</div></div>'+
    '<div class="stat-card"><div class="label">Closed</div><div class="value" style="color:var(--closed)">'+repo.issues.filter(i=>i.status==='closed').length+'</div></div></div>';
  if(repo.issues.length>0){
    ih+='<div class="chart-section"><div class="chart-card"><h3>By Priority</h3><div id="chart-prio"></div></div><div class="chart-card"><h3>By Type</h3><div id="chart-type"></div></div></div>';
    if(topL.length>0) ih+='<div class="chart-card" style="margin-bottom:20px"><h3>Labels</h3><div id="label-cloud"></div></div>';
    if(repo.differing_branches.length>0) ih+='<div class="chart-card" style="margin-bottom:20px"><h3>Branches with different issue sets</h3><div id="diff-branches"></div></div>';
    ih+='<div class="filters" id="filters-bar"></div><div class="issue-table-wrap"><table class="issues" id="issue-table"></table></div>';
  } else {
    ih+='<div style="color:var(--fg3);font-style:italic;margin-top:20px">No beads tracking in this repository</div>';
  }
  main.innerHTML=ih;
  if(repo.issues.length===0) return;
  const prioEl=document.getElementById('chart-prio');
  const pc={}; repo.issues.forEach(i=>{const p=i.priority??2;pc[p]=(pc[p]||0)+1});
  const mp=Math.max(...Object.values(pc));
  [0,1,2,3,4].forEach(p=>{const c=pc[p]||0;if(!c)return;prioEl.innerHTML+='<div class="hbar"><div class="label">P'+p+'</div><div class="bar" style="width:'+c/mp*100+'%%;background:'+P_COLORS[p]+'">'+c+'</div></div>';});
  const typeEl=document.getElementById('chart-type');
  const tc={}; repo.issues.forEach(i=>{const t=i.issue_type||'task';tc[t]=(tc[t]||0)+1});
  const mt=Math.max(...Object.values(tc));
  Object.entries(tc).sort((a,b)=>b[1]-a[1]).forEach(([t,c])=>{typeEl.innerHTML+='<div class="hbar"><div class="label">'+t+'</div><div class="bar" style="width:'+c/mt*100+'%%;background:'+(T_COLORS[t]||'#6b7280')+'">'+c+'</div></div>';});
  if(topL.length>0){const lc=document.getElementById('label-cloud');topL.forEach(([l,c])=>{lc.innerHTML+='<span class="badge-label" style="cursor:pointer;font-size:12px;padding:3px 8px;margin:2px" onclick="filterByLabel(\\''+l+'\\')">'+l+' ('+c+')</span>';});}
  if(repo.differing_branches.length>0){const db=document.getElementById('diff-branches');repo.differing_branches.forEach(d=>{db.innerHTML+='<div style="font-size:13px;color:var(--fg2);padding:4px 0">'+d.branch+' <span style="color:var(--fg3)">('+d.issue_lines+' lines)</span></div>';});}
  buildFilters(repo);
  renderIssueTable(repo);
}

function buildFilters(repo) {
  const bar=document.getElementById('filters-bar'); bar.innerHTML='';
  const s=document.createElement('input'); s.className='search'; s.placeholder='Search issues...'; s.value=searchQuery;
  s.oninput=()=>{searchQuery=s.value.toLowerCase();renderIssueTable(repo);}; bar.appendChild(s);
  const pg=document.createElement('div');pg.className='filter-group';
  [0,1,2,3,4].forEach(p=>{const c=repo.issues.filter(i=>(i.priority??2)===p).length;if(!c)return;const b=document.createElement('button');b.className='filter-btn'+(activeFilters.priority===p?' active':'');b.textContent='P'+p+' ('+c+')';b.style.borderColor=P_COLORS[p];b.onclick=()=>{activeFilters.priority=activeFilters.priority===p?null:p;renderIssueTable(repo);buildFilters(repo);};pg.appendChild(b);});
  bar.appendChild(pg);
  const tg=document.createElement('div');tg.className='filter-group';
  [...new Set(repo.issues.map(i=>i.issue_type||'task'))].sort().forEach(t=>{const c=repo.issues.filter(i=>(i.issue_type||'task')===t).length;const b=document.createElement('button');b.className='filter-btn'+(activeFilters.type===t?' active':'');b.textContent=t+' ('+c+')';b.onclick=()=>{activeFilters.type=activeFilters.type===t?null:t;renderIssueTable(repo);buildFilters(repo);};tg.appendChild(b);});
  bar.appendChild(tg);
  const sg=document.createElement('div');sg.className='filter-group';
  ['open','in_progress','closed'].forEach(st=>{const c=repo.issues.filter(i=>(i.status||'open')===st).length;if(!c)return;const b=document.createElement('button');b.className='filter-btn'+(activeFilters.status===st?' active':'');b.textContent=st.replace('_',' ')+' ('+c+')';b.onclick=()=>{activeFilters.status=activeFilters.status===st?null:st;renderIssueTable(repo);buildFilters(repo);};sg.appendChild(b);});
  bar.appendChild(sg);
}

function filterByLabel(l){searchQuery=l;const s=document.querySelector('.search');if(s)s.value=l;const repo=DATA.repos.find(r=>document.querySelector('.nav-item.active')?.id==='nav-repo-'+r.name);if(repo)renderIssueTable(repo);}

function renderIssueTable(repo) {
  const table=document.getElementById('issue-table'); if(!table)return;
  let issues=[...repo.issues];
  if(activeFilters.priority!==null)issues=issues.filter(i=>(i.priority??2)===activeFilters.priority);
  if(activeFilters.type)issues=issues.filter(i=>(i.issue_type||'task')===activeFilters.type);
  if(activeFilters.status)issues=issues.filter(i=>(i.status||'open')===activeFilters.status);
  if(searchQuery)issues=issues.filter(i=>(i.title||'').toLowerCase().includes(searchQuery)||(i.id||'').toLowerCase().includes(searchQuery)||(i.labels||[]).some(l=>l.toLowerCase().includes(searchQuery))||(i.description||'').toLowerCase().includes(searchQuery));
  if(currentSort.col){issues.sort((a,b)=>{let va,vb;switch(currentSort.col){case'priority':va=a.priority??2;vb=b.priority??2;break;case'type':va=a.issue_type||'task';vb=b.issue_type||'task';break;case'status':va=a.status||'open';vb=b.status||'open';break;case'title':va=(a.title||'').toLowerCase();vb=(b.title||'').toLowerCase();break;case'id':va=a.id||'';vb=b.id||'';break;default:return 0;}if(va<vb)return currentSort.asc?-1:1;if(va>vb)return currentSort.asc?1:-1;return 0;});}
  else{issues.sort((a,b)=>(a.priority??2)-(b.priority??2));}
  const cols=['status','id','priority','type','title','labels','deps'];
  const sortable=['id','priority','type','status','title'];
  let h='<thead><tr>';
  cols.forEach(c=>{const is=sortable.includes(c);const isd=currentSort.col===c;const ar=isd?(currentSort.asc?'\\u25b2':'\\u25bc'):'\\u25b2';h+='<th class="'+(isd?'sorted':'')+'" '+(is?'onclick="sortBy(\\''+c+'\\',\\''+repo.name+'\\')'+'"':'')+'>'+c+(is?'<span class="sort-arrow">'+ar+'</span>':'')+'</th>';});
  h+='</tr></thead><tbody>';
  const im={};repo.issues.forEach(i=>im[i.id]=i);
  issues.forEach(i=>{
    const bb=(i.blocked_by||[]).filter(id=>im[id]);
    const bl=(i.blocks||[]).filter(id=>im[id]);
    const dh=[...bb.map(id=>'<span style="color:var(--p0)">\\u2190 '+id+'</span>'),...bl.map(id=>'<span style="color:var(--closed)">\\u2192 '+id+'</span>')].join(' ');
    h+='<tr><td>'+statusIcon(i.status||'open')+'</td><td style="white-space:nowrap;font-family:monospace;font-size:12px">'+(i.id||'')+'</td><td>'+priorityBadge(i.priority??2)+'</td><td>'+typeBadge(i.issue_type||'task')+'</td><td class="title">'+(i.title||'')+'</td><td>'+(i.labels||[]).map(l=>'<span class="badge-label">'+l+'</span>').join('')+'</td><td class="deps">'+dh+'</td></tr>';
  });
  table.innerHTML=h+'</tbody>';
}

function sortBy(col,rn){if(currentSort.col===col)currentSort.asc=!currentSort.asc;else{currentSort.col=col;currentSort.asc=true;}const r=DATA.repos.find(r=>r.name===rn);if(r)renderIssueTable(r);}

function initNav(){const nr=document.getElementById('nav-repos');DATA.repos.forEach(r=>{const it=document.createElement('div');it.className='nav-item';it.id='nav-repo-'+r.name;it.onclick=()=>showRepo(r.name);const d=document.createElement('div');d.className='dot';d.style.background=r.issues.length>0?'#22c55e':'#475569';it.appendChild(d);it.appendChild(document.createTextNode(r.name));if(r.issues.length>0){const b=document.createElement('span');b.className='badge';b.textContent=r.issues.filter(i=>i.status!=='closed').length||r.issues.length;it.appendChild(b);}nr.appendChild(it);});}
initNav();showDashboard();
</script>
</body>
