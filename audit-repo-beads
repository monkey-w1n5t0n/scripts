def run(cmd, cwd=None):
    try:
        r = subprocess.run(cmd, shell=True, capture_output=True, text=True, cwd=cwd, timeout=15)
        return r.stdout.strip()
    except:
        return ""

def parse_jsonl(text):
    issues = []
    for line in text.strip().split('\n'):
        line = line.strip()
        if not line:
            continue
        try:
            issues.append(json.loads(line))
        except:
            pass
    return issues

repos = []
for repo_dir in repo_dirs:
    repo_dir = repo_dir.rstrip('/')
    name = os.path.basename(repo_dir)
    current_branch = run("git symbolic-ref --short HEAD", cwd=repo_dir) or "(detached)"
    status_out = run("git status --porcelain", cwd=repo_dir)
    dirty = len(status_out) > 0
    last_commit = run("git log -1 --format='%aI'", cwd=repo_dir)

    branch_lines = run("git branch -a --no-color", cwd=repo_dir).split('\n')
    branches = []
    for b in branch_lines:
        b = b.strip().lstrip('* ').strip()
        if not b or 'HEAD' in b:
            continue
        branches.append(b)

    branches_with_beads = []
    for b in branches:
        tree = run(f"git ls-tree --name-only '{b}' .beads/", cwd=repo_dir)
        if tree:
            branches_with_beads.append(b)

    issues = []
    jsonl_text = run(f"git show '{current_branch}:.beads/issues.jsonl'", cwd=repo_dir)
    if not jsonl_text:
        jsonl_path = os.path.join(repo_dir, '.beads', 'issues.jsonl')
        if os.path.exists(jsonl_path):
            with open(jsonl_path) as f:
                jsonl_text = f.read()
    if jsonl_text:
        issues = parse_jsonl(jsonl_text)

    current_hash = run(f"git rev-parse '{current_branch}:.beads/issues.jsonl'", cwd=repo_dir) or "none"
    differing = []
    for b in branches_with_beads:
        if b == current_branch:
            continue
        bh = run(f"git rev-parse '{b}:.beads/issues.jsonl'", cwd=repo_dir) or "none"
        if bh != current_hash:
            lc = run(f"git show '{b}:.beads/issues.jsonl'", cwd=repo_dir).count('\n')
            differing.append({"branch": b, "issue_lines": lc})

    repos.append({
        "name": name,
        "path": repo_dir,
        "current_branch": current_branch,
        "dirty": dirty,
        "last_commit": last_commit,
        "branch_count": len(branches),
        "branches_with_beads": len(branches_with_beads),
        "differing_branches": differing,
        "issues": issues,
