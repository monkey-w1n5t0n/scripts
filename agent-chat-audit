                <div>
                  <div class="section-label">Latest assistant replies</div>
                  <div class="agent-tail">${tail}</div>
                </div>
              </div>
              <div class="session-actions">
                <button class="${session.review_later ? "button-active" : ""}" data-review="${escapeHtml(session.session_key)}" data-review-value="${session.review_later ? "0" : "1"}">
