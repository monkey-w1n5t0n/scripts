          sort: document.getElementById("sort"),
          limit: document.getElementById("limit"),
          reviewOnly: document.getElementById("review-only"),
          needsAttention: document.getElementById("needs-attention"),
          results: document.getElementById("results"),
          status: document.getElementById("status"),
          statSessions: document.getElementById("stat-sessions"),
          statAttention: document.getElementById("stat-attention"),
          statDays: document.getElementById("stat-days"),
        };

        function escapeHtml(value) {
          return value
            .replaceAll("&", "&amp;")
            .replaceAll("<", "&lt;")
            .replaceAll(">", "&gt;");
        }

        function relativeTime(value) {
          if (!value) return "unknown";
          const then = new Date(value);
          const diffMs = Date.now() - then.getTime();
          const diffMinutes = Math.round(diffMs / 60000);
          if (Math.abs(diffMinutes) < 60) return `${diffMinutes}m ago`;
          const diffHours = Math.round(diffMinutes / 60);
          if (Math.abs(diffHours) < 48) return `${diffHours}h ago`;
          const diffDays = Math.round(diffHours / 24);
          return `${diffDays}d ago`;
        }

        function attentionOpacity(score) {
          return Math.max(0.16, Math.min(1, score + 0.14));
        }

        function copySvg() {
          return `
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <rect x="9" y="9" width="10" height="10" rx="2"></rect>
              <path d="M7 15H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h7a2 2 0 0 1 2 2v1"></path>
            </svg>
          `;
        }

        function buildSessionCard(session) {
          const tail = session.last_agent_messages.length
            ? session.last_agent_messages.map(item => `<div class="tail-item">${escapeHtml(item)}</div>`).join("")
            : `<div class="tail-item">No assistant reply was captured.</div>`;

          const flags = session.flags.map(flag => `<span class="flag">${escapeHtml(flag)}</span>`).join("");
          const detailId = `detail-${CSS.escape(session.session_key)}`;
          const scorePercent = Math.round(session.attention_score * 100);
          const reviewBadge = session.review_later ? `<span class="flag">review later</span>` : "";

          return `
            <article class="session" data-session-key="${escapeHtml(session.session_key)}" style="--attention:${attentionOpacity(session.attention_score)}">
              <div class="session-main">
                <div>
                  <div class="headline">
                    <span class="badge">${escapeHtml(session.agent)}</span>
                    <span class="flag">${scorePercent}% follow-up</span>
                    ${reviewBadge}
                    ${flags}
                  </div>
                  <div class="title-row">
                    <h2 class="title">${escapeHtml(session.title)}</h2>
