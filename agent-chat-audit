DEFAULT_DB_PATH = Path.home() / ".local" / "state" / "agent-chat-audit" / "index.sqlite"
DEFAULT_PORT = 8421
DEFAULT_DAYS = 7


ATTENTION_PATTERNS = [
    ("asked_question", re.compile(r"\?$")),
    ("waiting_for_feedback", re.compile(r"\b(feedback|what would you like|let me know|which do you want)\b")),
    ("needs_confirmation", re.compile(r"\b(confirm|confirmation|approve|approval|shall i|should i|okay to)\b")),
    ("blocked", re.compile(r"\b(blocked|can't proceed|cannot proceed|need access|need input|need you to|unblock)\b")),
    ("auth_error", re.compile(r"\b(auth|login|401|403|api error|authentication_failed|please run /login)\b")),
    ("git_follow_up", re.compile(r"\b(commit|push|review|merge|pull request|pr)\b")),
]

DONE_PATTERNS = [
    re.compile(r"\b(done|completed|finished|resolved|implemented|tests pass(?:ed)?|pushed|closed)\b"),
    re.compile(r"\bno further action\b"),
]


@dataclass
class Message:
    role: str
    text: str
    ts: str


@dataclass
class SessionRecord:
    session_key: str
    session_id: str
    agent: str
    source_path: str
    cwd: str
    started_at: str
    updated_at: str
    title: str
    first_user_message: str
    last_user_message: str
    last_agent_messages: list[str]
    message_count: int
    attention_score: float
    flags: list[str]
    messages: list[Message]


def default_roots() -> dict[str, Path]:
    home = Path.home()
    return {
        "claude": home / ".claude",
        "claude-gp": home / ".claude-gp",
        "codex": home / ".codex",
        "factory": home / ".factory",
    }


def utc_now() -> str:
    return dt.datetime.now(dt.timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def ensure_parent(path: Path) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)


def iter_jsonl(path: Path) -> Iterable[dict[str, Any]]:
    with path.open("r", encoding="utf-8", errors="replace") as handle:
        for raw_line in handle:
            line = raw_line.strip()
            if not line:
                continue
            try:
                obj = json.loads(line)
            except json.JSONDecodeError:
                continue
            if isinstance(obj, dict):
                yield obj


def normalize_space(text: str) -> str:
    return re.sub(r"\s+", " ", text).strip()


def compact_text(text: str, limit: int = 220) -> str:
    text = normalize_space(text)
    if len(text) <= limit:
        return text
    return text[: limit - 3].rstrip() + "..."


def strip_known_prefixes(text: str) -> str:
    text = text.lstrip()
    if text.startswith("# AGENTS.md instructions for "):
        match = re.match(r"^# AGENTS\.md instructions for .*?</INSTRUCTIONS>\s*", text, flags=re.DOTALL)
        if match:
            text = text[match.end() :]
    return text.strip()


def is_noise_text(text: str) -> bool:
    if not text:
        return True
    stripped = strip_known_prefixes(text)
    if not stripped:
        return True
    if stripped in {"Tool loaded.", "TODO List Updated"}:
        return True
    if stripped.startswith("<local-command-caveat>"):
        return True
    if stripped.startswith("<command-name>"):
        return True
    if stripped.startswith("<command-message>"):
        return True
    if stripped.startswith("<local-command-stdout>"):
        return True
    if stripped.startswith("<system-reminder>") and len(stripped) > 200:
        return True
    return False


def extract_text(value: Any) -> str:
    if value is None:
        return ""
    if isinstance(value, str):
        return value
    if isinstance(value, list):
        parts: list[str] = []
        for item in value:
            part = extract_text(item)
            if part:
                parts.append(part)
        return "\n".join(parts)
    if isinstance(value, dict):
        kind = value.get("type")
        if kind in {"text", "input_text", "output_text", "summary_text"}:
            return str(value.get("text", ""))
        if kind in {"thinking", "tool_use", "tool_reference"}:
            return ""
        if kind == "tool_result":
            content = value.get("content")
            if isinstance(content, str):
                return ""
            return extract_text(content)
        if "text" in value and isinstance(value["text"], str):
            return value["text"]
        if "content" in value:
            return extract_text(value["content"])
        if "message" in value:
            return extract_text(value["message"])
    return ""


def clean_text(text: str) -> str:
    return normalize_space(strip_known_prefixes(text))


def parse_roots(root_args: list[str] | None) -> dict[str, Path]:
    roots = default_roots()
    for raw in root_args or []:
        if "=" not in raw:
            raise SystemExit(f"Invalid --root value: {raw!r}. Expected agent=/path")
        agent, path_str = raw.split("=", 1)
        agent = agent.strip()
        if agent not in roots:
            raise SystemExit(f"Unknown agent {agent!r}. Expected one of: {', '.join(sorted(roots))}")
        roots[agent] = Path(path_str).expanduser()
    return roots


def discover_files(agent: str, root: Path) -> list[Path]:
    if not root.exists():
        return []
    files: list[Path] = []
    if agent == "claude":
        projects = root / "projects"
        if projects.exists():
            for path in projects.rglob("*.jsonl"):
                if "/subagents/" in path.as_posix():
                    continue
                if path.name.startswith("agent-"):
                    continue
                files.append(path)
        transcripts = root / "transcripts"
        if transcripts.exists():
            files.extend(sorted(transcripts.glob("*.jsonl")))
    elif agent == "claude-gp":
        projects = root / "projects"
        if projects.exists():
            for path in projects.rglob("*.jsonl"):
                if "/subagents/" in path.as_posix():
                    continue
                if path.name.startswith("agent-"):
                    continue
                files.append(path)
    elif agent == "codex":
        for rel in ("sessions", "archived_sessions"):
            base = root / rel
            if base.exists():
                files.extend(sorted(base.rglob("*.jsonl")))
    elif agent == "factory":
        base = root / "sessions"
        if base.exists():
            files.extend(sorted(base.rglob("*.jsonl")))
    return sorted({path.resolve() for path in files if path.suffix == ".jsonl"})


def within_days(path: Path, days: int | None) -> bool:
    if days is None:
        return True
    cutoff = dt.datetime.now(dt.timezone.utc).timestamp() - (days * 86400)
    return path.stat().st_mtime >= cutoff


def compute_attention(messages: list[Message]) -> tuple[float, list[str]]:
    flags: list[str] = []
    assistant_messages = [message for message in messages if message.role == "assistant" and message.text]
    if not assistant_messages:
        score = 0.45 if any(message.role == "user" for message in messages) else 0.0
        if score:
            flags.append("no_reply")
        return score, flags

    latest = normalize_space(assistant_messages[-1].text).lower()
    score = 0.1
    for flag, pattern in ATTENTION_PATTERNS:
        if pattern.search(latest):
            flags.append(flag)
            score += 0.18
    for pattern in DONE_PATTERNS:
        if pattern.search(latest):
            score -= 0.2
            flags.append("looks_done")
            break
    score = max(0.0, min(1.0, score))
    return score, sorted(set(flags))


def build_session_record(agent: str, source_path: Path, session_id: str, cwd: str, started_at: str, messages: list[Message]) -> SessionRecord:
    meaningful = [message for message in messages if message.text and not is_noise_text(message.text)]
    user_messages = [message for message in meaningful if message.role == "user"]
    assistant_messages = [message for message in meaningful if message.role == "assistant"]

    first_user = user_messages[0].text if user_messages else ""
    last_user = user_messages[-1].text if user_messages else ""
    last_agent_messages = [message.text for message in assistant_messages[-5:]]
    updated_at = meaningful[-1].ts if meaningful else started_at
    title = compact_text(first_user or source_path.stem, 120)
    attention_score, flags = compute_attention(meaningful)
    session_key = f"{agent}:{source_path}"

    return SessionRecord(
        session_key=session_key,
        session_id=session_id or source_path.stem,
        agent=agent,
        source_path=str(source_path),
        cwd=cwd,
        started_at=started_at,
        updated_at=updated_at,
        title=title,
        first_user_message=compact_text(first_user, 500),
        last_user_message=compact_text(last_user, 500),
        last_agent_messages=[compact_text(message, 500) for message in last_agent_messages],
        message_count=len(meaningful),
        attention_score=attention_score,
        flags=flags,
        messages=[Message(role=message.role, text=compact_text(message.text, 1500), ts=message.ts) for message in meaningful],
    )


def parse_claude_file(agent: str, source_path: Path) -> SessionRecord | None:
    messages: list[Message] = []
    session_id = ""
    cwd = ""
    started_at = ""

    for obj in iter_jsonl(source_path):
        session_id = session_id or str(obj.get("sessionId", ""))
        cwd = cwd or str(obj.get("cwd", ""))
        timestamp = str(obj.get("timestamp", ""))
        if timestamp and not started_at:
            started_at = timestamp
        record_type = obj.get("type")

        if record_type == "user":
            if obj.get("isMeta"):
                continue
            payload = obj.get("message", obj)
            text = extract_text(payload.get("content"))
            if is_noise_text(text):
                continue
            messages.append(Message("user", clean_text(text), timestamp))
        elif record_type == "assistant":
            payload = obj.get("message", obj)
            text = extract_text(payload.get("content"))
            if not text and obj.get("error"):
                text = str(obj["error"])
            if is_noise_text(text):
                continue
            messages.append(Message("assistant", clean_text(text), timestamp))

    if not started_at:
        started_at = dt.datetime.fromtimestamp(source_path.stat().st_mtime, tz=dt.timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")
    if not messages and not source_path.name.startswith("ses_"):
        return None
    if not messages and source_path.name.startswith("ses_"):
        for obj in iter_jsonl(source_path):
            text = extract_text(obj.get("content"))
            timestamp = str(obj.get("timestamp", started_at))
            if text:
                messages.append(Message("user", clean_text(text), timestamp))
    return build_session_record(agent, source_path, session_id or source_path.stem, cwd, started_at, messages)


def parse_codex_file(source_path: Path) -> SessionRecord | None:
    messages: list[Message] = []
    session_id = ""
    cwd = ""
    started_at = ""

    for obj in iter_jsonl(source_path):
        record_type = obj.get("type")
        timestamp = str(obj.get("timestamp", ""))
        if record_type == "session_meta":
            payload = obj.get("payload", {})
            session_id = session_id or str(payload.get("id", ""))
            cwd = cwd or str(payload.get("cwd", ""))
            started_at = started_at or str(payload.get("timestamp", "")) or timestamp
            continue
        if record_type != "response_item":
            continue
        payload = obj.get("payload", {})
        if payload.get("type") != "message":
            continue
        role = payload.get("role")
        text = extract_text(payload.get("content"))
        if role not in {"user", "assistant"} or is_noise_text(text):
            continue
        messages.append(Message(str(role), clean_text(text), timestamp))

    if not started_at:
        started_at = dt.datetime.fromtimestamp(source_path.stat().st_mtime, tz=dt.timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")
    if not messages:
        return None
    return build_session_record("codex", source_path, session_id or source_path.stem, cwd, started_at, messages)


def parse_factory_file(source_path: Path) -> SessionRecord | None:
    messages: list[Message] = []
    session_id = ""
    cwd = ""
    started_at = ""

    for obj in iter_jsonl(source_path):
        record_type = obj.get("type")
        if record_type == "session_start":
            session_id = session_id or str(obj.get("id", ""))
            cwd = cwd or str(obj.get("cwd", ""))
            continue
        if record_type != "message":
            continue
        payload = obj.get("message", {})
        role = payload.get("role")
        timestamp = str(obj.get("timestamp", ""))
        started_at = started_at or timestamp
        text = extract_text(payload.get("content"))
        if role not in {"user", "assistant"} or is_noise_text(text):
            continue
        messages.append(Message(str(role), clean_text(text), timestamp))

    if not started_at:
        started_at = dt.datetime.fromtimestamp(source_path.stat().st_mtime, tz=dt.timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")
    if not messages:
        return None
    return build_session_record("factory", source_path, session_id or source_path.stem, cwd, started_at, messages)


def parse_session_file(agent: str, source_path: Path) -> SessionRecord | None:
    if agent in {"claude", "claude-gp"}:
        return parse_claude_file(agent, source_path)
    if agent == "codex":
        return parse_codex_file(source_path)
    if agent == "factory":
        return parse_factory_file(source_path)
    raise ValueError(f"Unsupported agent: {agent}")


def connect_db(db_path: Path) -> sqlite3.Connection:
    ensure_parent(db_path)
    conn = sqlite3.connect(db_path)
    conn.row_factory = sqlite3.Row
    conn.execute("PRAGMA journal_mode=WAL")
    conn.executescript(
        """
        CREATE TABLE IF NOT EXISTS source_files (
            path TEXT PRIMARY KEY,
            agent TEXT NOT NULL,
            size INTEGER NOT NULL,
            mtime_ns INTEGER NOT NULL,
            indexed_at TEXT NOT NULL
        );

        CREATE TABLE IF NOT EXISTS sessions (
            session_key TEXT PRIMARY KEY,
            session_id TEXT NOT NULL,
            agent TEXT NOT NULL,
            source_path TEXT NOT NULL UNIQUE,
            cwd TEXT NOT NULL,
            started_at TEXT NOT NULL,
            updated_at TEXT NOT NULL,
            title TEXT NOT NULL,
            first_user_message TEXT NOT NULL,
            last_user_message TEXT NOT NULL,
            last_agent_messages_json TEXT NOT NULL,
            message_count INTEGER NOT NULL,
            attention_score REAL NOT NULL,
            flags_json TEXT NOT NULL
        );

        CREATE TABLE IF NOT EXISTS messages (
            session_key TEXT NOT NULL,
            ordinal INTEGER NOT NULL,
            role TEXT NOT NULL,
            ts TEXT NOT NULL,
            text TEXT NOT NULL,
            PRIMARY KEY (session_key, ordinal),
            FOREIGN KEY (session_key) REFERENCES sessions(session_key) ON DELETE CASCADE
        );

        CREATE TABLE IF NOT EXISTS review_later (
            session_key TEXT PRIMARY KEY,
            marked_at TEXT NOT NULL,
            FOREIGN KEY (session_key) REFERENCES sessions(session_key) ON DELETE CASCADE
        );

        CREATE TABLE IF NOT EXISTS hidden_sources (
            source_path TEXT PRIMARY KEY,
            hidden_at TEXT NOT NULL
        );

        CREATE INDEX IF NOT EXISTS idx_sessions_updated_at ON sessions(updated_at DESC);
        CREATE INDEX IF NOT EXISTS idx_sessions_agent ON sessions(agent);
        CREATE INDEX IF NOT EXISTS idx_messages_session_key ON messages(session_key, ordinal DESC);
        """
    )
    return conn


def upsert_session(conn: sqlite3.Connection, record: SessionRecord, size: int, mtime_ns: int) -> None:
    conn.execute(
        """
        INSERT INTO source_files(path, agent, size, mtime_ns, indexed_at)
        VALUES (?, ?, ?, ?, ?)
        ON CONFLICT(path) DO UPDATE SET
            agent=excluded.agent,
            size=excluded.size,
            mtime_ns=excluded.mtime_ns,
            indexed_at=excluded.indexed_at
        """,
        (record.source_path, record.agent, size, mtime_ns, utc_now()),
    )
    conn.execute("DELETE FROM messages WHERE session_key = ?", (record.session_key,))
    conn.execute(
        """
        INSERT INTO sessions(
            session_key, session_id, agent, source_path, cwd, started_at, updated_at,
            title, first_user_message, last_user_message, last_agent_messages_json,
            message_count, attention_score, flags_json
        ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        ON CONFLICT(session_key) DO UPDATE SET
            session_id=excluded.session_id,
            agent=excluded.agent,
            source_path=excluded.source_path,
            cwd=excluded.cwd,
            started_at=excluded.started_at,
            updated_at=excluded.updated_at,
            title=excluded.title,
            first_user_message=excluded.first_user_message,
            last_user_message=excluded.last_user_message,
            last_agent_messages_json=excluded.last_agent_messages_json,
            message_count=excluded.message_count,
            attention_score=excluded.attention_score,
            flags_json=excluded.flags_json
        """,
        (
            record.session_key,
            record.session_id,
            record.agent,
            record.source_path,
            record.cwd,
            record.started_at,
            record.updated_at,
            record.title,
            record.first_user_message,
            record.last_user_message,
            json.dumps(record.last_agent_messages),
            record.message_count,
            record.attention_score,
            json.dumps(record.flags),
        ),
    )
    conn.executemany(
        "INSERT INTO messages(session_key, ordinal, role, ts, text) VALUES (?, ?, ?, ?, ?)",
        [
            (record.session_key, index, message.role, message.ts, message.text)
            for index, message in enumerate(record.messages)
        ],
    )


def remove_missing_sources(conn: sqlite3.Connection, discovered_paths: set[str]) -> int:
    rows = conn.execute("SELECT path FROM source_files").fetchall()
    removed = 0
    for row in rows:
        path = row["path"]
        if path in discovered_paths:
            continue
        session = conn.execute("SELECT session_key FROM sessions WHERE source_path = ?", (path,)).fetchone()
        if session:
            conn.execute("DELETE FROM messages WHERE session_key = ?", (session["session_key"],))
            conn.execute("DELETE FROM sessions WHERE session_key = ?", (session["session_key"],))
        conn.execute("DELETE FROM source_files WHERE path = ?", (path,))
        removed += 1
    return removed


def delete_session_by_source(conn: sqlite3.Connection, source_path: str) -> None:
    session = conn.execute("SELECT session_key FROM sessions WHERE source_path = ?", (source_path,)).fetchone()
    if session:
        conn.execute("DELETE FROM review_later WHERE session_key = ?", (session["session_key"],))
        conn.execute("DELETE FROM messages WHERE session_key = ?", (session["session_key"],))
        conn.execute("DELETE FROM sessions WHERE session_key = ?", (session["session_key"],))
    conn.execute("DELETE FROM source_files WHERE path = ?", (source_path,))


def ingest(db_path: Path, roots: dict[str, Path], days: int | None, verbose: bool = False) -> dict[str, int]:
    conn = connect_db(db_path)
    hidden_sources = {row["source_path"] for row in conn.execute("SELECT source_path FROM hidden_sources")}
    discovered: list[tuple[str, Path]] = []
    for agent, root in roots.items():
        for path in discover_files(agent, root):
            if not within_days(path, days):
                continue
            if str(path) in hidden_sources:
                delete_session_by_source(conn, str(path))
                continue
            discovered.append((agent, path))

    discovered_paths = {str(path) for _, path in discovered}
    existing = {
        row["path"]: (row["size"], row["mtime_ns"])
        for row in conn.execute("SELECT path, size, mtime_ns FROM source_files")
    }

    new_count = 0
    updated_count = 0
    skipped_count = 0
    parsed_count = 0

    for agent, path in discovered:
        stat = path.stat()
        cached = existing.get(str(path))
        if cached == (stat.st_size, stat.st_mtime_ns):
            skipped_count += 1
            continue
        record = parse_session_file(agent, path)
        if record is None:
            conn.execute("DELETE FROM source_files WHERE path = ?", (str(path),))
            conn.execute("DELETE FROM sessions WHERE source_path = ?", (str(path),))
            continue
        upsert_session(conn, record, stat.st_size, stat.st_mtime_ns)
        parsed_count += 1
        if cached is None:
            new_count += 1
        else:
            updated_count += 1
        if verbose:
            print(f"indexed {agent:9s} {path}")

    removed_count = remove_missing_sources(conn, discovered_paths)
    conn.commit()
    conn.close()
    return {
        "discovered": len(discovered),
        "days": days,
        "parsed": parsed_count,
        "new": new_count,
        "updated": updated_count,
        "skipped": skipped_count,
        "removed": removed_count,
    }


def iso_threshold(days: int) -> str:
    threshold = dt.datetime.now(dt.timezone.utc) - dt.timedelta(days=days)
    return threshold.replace(microsecond=0).isoformat().replace("+00:00", "Z")


def session_workdir(row: sqlite3.Row | dict[str, Any]) -> str:
    cwd = str(row["cwd"] or "").strip()
    if cwd:
        return cwd
    return str(Path(str(row["source_path"])).parent)


def resume_command(agent: str, session_id: str, cwd: str) -> str:
    prefix = f"cd {shlex.quote(cwd)} && " if cwd else ""
    session = shlex.quote(session_id)
    if agent == "codex":
        return f"{prefix}codex resume {session}"
    if agent == "claude":
        return f"{prefix}claude -r {session}"
    if agent == "claude-gp":
        return f"{prefix}CLAUDE_CONFIG_DIR=~/.claude-gp claude --dangerously-skip-permissions -r {session}"
    if agent == "factory":
        return f"{prefix}droid -r {session}"
    return session


def query_sessions(
    conn: sqlite3.Connection,
    days: int,
    agent: str,
    needs_attention: bool,
    review_only: bool,
    query: str,
    limit: int,
    sort: str,
) -> list[dict[str, Any]]:
    clauses = ["updated_at >= ?"]
    params: list[Any] = [iso_threshold(days)]
    if agent:
        clauses.append("agent = ?")
        params.append(agent)
    if needs_attention:
        clauses.append("attention_score >= 0.35")
    if review_only:
        clauses.append("review_later.session_key IS NOT NULL")
    if query:
        clauses.append("(lower(title) LIKE ? OR lower(cwd) LIKE ? OR lower(first_user_message) LIKE ? OR lower(last_user_message) LIKE ?)")
        needle = f"%{query.lower()}%"
        params.extend([needle, needle, needle, needle])

    order = "attention_score DESC, updated_at DESC" if sort == "attention" else "updated_at DESC, attention_score DESC"
    sql = f"""
        SELECT sessions.*, review_later.marked_at AS review_later_marked_at
        FROM sessions
        LEFT JOIN review_later ON review_later.session_key = sessions.session_key
        LEFT JOIN hidden_sources ON hidden_sources.source_path = sessions.source_path
        WHERE hidden_sources.source_path IS NULL AND {' AND '.join(clauses)}
        ORDER BY {order}
        LIMIT ?
    """
    params.append(limit)
    rows = conn.execute(sql, params).fetchall()
    results: list[dict[str, Any]] = []
    for row in rows:
        cwd = session_workdir(row)
        results.append(
            {
                "session_key": row["session_key"],
                "session_id": row["session_id"],
                "agent": row["agent"],
                "source_path": row["source_path"],
                "cwd": cwd,
                "started_at": row["started_at"],
                "updated_at": row["updated_at"],
                "title": row["title"],
                "first_user_message": row["first_user_message"],
                "last_user_message": row["last_user_message"],
                "last_agent_messages": json.loads(row["last_agent_messages_json"]),
                "message_count": row["message_count"],
                "attention_score": row["attention_score"],
                "flags": json.loads(row["flags_json"]),
                "review_later": bool(row["review_later_marked_at"]),
                "resume_command": resume_command(row["agent"], row["session_id"], cwd),
            }
        )
    return results


def query_session_detail(conn: sqlite3.Connection, session_key: str) -> dict[str, Any] | None:
    row = conn.execute(
        """
        SELECT sessions.*, review_later.marked_at AS review_later_marked_at
        FROM sessions
        LEFT JOIN review_later ON review_later.session_key = sessions.session_key
        LEFT JOIN hidden_sources ON hidden_sources.source_path = sessions.source_path
        WHERE sessions.session_key = ?
          AND hidden_sources.source_path IS NULL
        """,
        (session_key,),
    ).fetchone()
    if row is None:
        return None
    cwd = session_workdir(row)
    messages = conn.execute(
        """
        SELECT role, ts, text
        FROM messages
        WHERE session_key = ?
        ORDER BY ordinal DESC
        LIMIT 30
        """,
        (session_key,),
    ).fetchall()
    return {
        "session_key": row["session_key"],
        "session_id": row["session_id"],
        "agent": row["agent"],
        "cwd": cwd,
        "source_path": row["source_path"],
        "started_at": row["started_at"],
        "updated_at": row["updated_at"],
        "title": row["title"],
        "attention_score": row["attention_score"],
        "flags": json.loads(row["flags_json"]),
        "review_later": bool(row["review_later_marked_at"]),
        "resume_command": resume_command(row["agent"], row["session_id"], cwd),
        "messages": [
            {"role": message["role"], "ts": message["ts"], "text": message["text"]}
            for message in reversed(messages)
        ],
    }


def set_review_later(conn: sqlite3.Connection, session_key: str, review_later: bool) -> bool:
    exists = conn.execute("SELECT 1 FROM sessions WHERE session_key = ?", (session_key,)).fetchone()
    if exists is None:
        return False
    if review_later:
        conn.execute(
            """
            INSERT INTO review_later(session_key, marked_at)
            VALUES (?, ?)
            ON CONFLICT(session_key) DO UPDATE SET marked_at=excluded.marked_at
            """,
            (session_key, utc_now()),
        )
    else:
        conn.execute("DELETE FROM review_later WHERE session_key = ?", (session_key,))
    conn.commit()
    return True


def hide_session(conn: sqlite3.Connection, session_key: str) -> bool:
    row = conn.execute("SELECT source_path FROM sessions WHERE session_key = ?", (session_key,)).fetchone()
    if row is None:
        return False
    source_path = row["source_path"]
    conn.execute(
        """
        INSERT INTO hidden_sources(source_path, hidden_at)
        VALUES (?, ?)
        ON CONFLICT(source_path) DO UPDATE SET hidden_at=excluded.hidden_at
        """,
        (source_path, utc_now()),
    )
    delete_session_by_source(conn, source_path)
    conn.commit()
    return True


