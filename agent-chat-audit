              </div>
              <div class="detail" id="${detailId}"></div>
            </article>
          `;
        }

        async function fetchJson(url) {
          const response = await fetch(url);
          if (!response.ok) {
            throw new Error(`Request failed: ${response.status}`);
          }
          return response.json();
        }

        async function loadSessions() {
          state.loading = true;
          elements.status.textContent = "Loading sessions...";
          const params = new URLSearchParams({
            days: elements.days.value || "7",
            agent: elements.agent.value,
            q: elements.query.value.trim(),
            sort: elements.sort.value,
            limit: elements.limit.value,
          });
          if (elements.needsAttention.checked) {
            params.set("needs_attention", "1");
          }
          if (elements.reviewOnly.checked) {
            params.set("review_only", "1");
          }

          try {
            const data = await fetchJson(`/api/sessions?${params.toString()}`);
            elements.results.innerHTML = data.sessions.length
              ? data.sessions.map(buildSessionCard).join("")
              : `<div class="empty">No sessions matched the current filters.</div>`;

            const attentionCount = data.sessions.filter(session => session.attention_score >= 0.35).length;
            elements.status.textContent = `${data.sessions.length} sessions loaded`;
            elements.statSessions.textContent = String(data.sessions.length);
            elements.statAttention.textContent = String(attentionCount);
            elements.statDays.textContent = `${params.get("days")} days`;
          } catch (error) {
            elements.results.innerHTML = `<div class="empty">${escapeHtml(String(error))}</div>`;
            elements.status.textContent = "Load failed";
          } finally {
            state.loading = false;
          }
        }

        async function toggleDetail(sessionKey) {
          const detail = document.getElementById(`detail-${CSS.escape(sessionKey)}`);
          if (!detail) return;
          if (detail.classList.contains("open")) {
            detail.classList.remove("open");
            detail.innerHTML = "";
            return;
          }

          detail.classList.add("open");
          detail.innerHTML = "Loading tail...";
          let payload = state.detailCache.get(sessionKey);
          if (!payload) {
            payload = await fetchJson(`/api/session?session_key=${encodeURIComponent(sessionKey)}`);
            state.detailCache.set(sessionKey, payload);
          }

          const messages = payload.messages.length
            ? payload.messages.map(message => `
                <div class="message ${escapeHtml(message.role)}">
                  <div class="message-meta">
                    <span>${escapeHtml(message.role)}</span>
                    <span>${escapeHtml(message.ts || "")}</span>
                  </div>
                  <div>${escapeHtml(message.text)}</div>
                </div>
              `).join("")
            : "<div>No normalized messages stored for this session.</div>";

          detail.innerHTML = `
            <div class="section-label">Transcript tail</div>
            <div class="path">${escapeHtml(payload.source_path)}</div>
            <div class="path">${escapeHtml(payload.resume_command)}</div>
            <div class="message-log">${messages}</div>
          `;
        }

        async function copyResumeCommand(sessionKey, button) {
          try {
            const data = await fetchJson(`/api/session?session_key=${encodeURIComponent(sessionKey)}`);
            if (navigator.clipboard && navigator.clipboard.writeText) {
              await navigator.clipboard.writeText(data.resume_command);
            } else {
              window.prompt("Copy resume command:", data.resume_command);
            }
            const oldTitle = button.title;
            button.title = "Copied";
            button.classList.add("button-active");
            setTimeout(() => {
              button.title = oldTitle;
              button.classList.remove("button-active");
            }, 900);
          } catch (error) {
            console.error(error);
          }
        }

        async function toggleReviewLater(sessionKey, reviewLater) {
          const response = await fetch("/api/review-later", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ session_key: sessionKey, review_later: reviewLater }),
          });
          if (!response.ok) {
            throw new Error(`Failed to update review-later: ${response.status}`);
          }
          state.detailCache.delete(sessionKey);
          await loadSessions();
        }

        async function hideSession(sessionKey) {
          const response = await fetch("/api/hide-session", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ session_key: sessionKey }),
          });
          if (!response.ok) {
            throw new Error(`Failed to hide session: ${response.status}`);
          }
          state.detailCache.delete(sessionKey);
          await loadSessions();
        }

        document.addEventListener("click", async event => {
          const copyButton = event.target.closest("button[data-copy]");
          if (copyButton) {
            await copyResumeCommand(copyButton.getAttribute("data-copy"), copyButton);
            return;
          }

          const reviewButton = event.target.closest("button[data-review]");
          if (reviewButton) {
            const sessionKey = reviewButton.getAttribute("data-review");
            const reviewLater = reviewButton.getAttribute("data-review-value") === "1";
            await toggleReviewLater(sessionKey, reviewLater);
            return;
          }

          const hideButton = event.target.closest("button[data-hide]");
          if (hideButton) {
            const sessionKey = hideButton.getAttribute("data-hide");
            const confirmed = window.confirm("Hide this chat permanently from future ingests?");
            if (confirmed) {
              await hideSession(sessionKey);
            }
            return;
          }

          const button = event.target.closest("button[data-toggle]");
          if (!button) return;
          await toggleDetail(button.getAttribute("data-toggle"));
        });

        let debounce;
        for (const element of [elements.days, elements.agent, elements.sort, elements.limit, elements.reviewOnly, elements.needsAttention]) {
          element.addEventListener("change", loadSessions);
        }
        elements.query.addEventListener("input", () => {
          clearTimeout(debounce);
          debounce = setTimeout(loadSessions, 200);
        });

        loadSessions();
      </script>
    </body>
    </html>
    """
)


def make_handler(db_path: Path, default_days: int):
    class Handler(BaseHTTPRequestHandler):
        def do_GET(self) -> None:
            parsed = urllib.parse.urlparse(self.path)
            if parsed.path == "/":
                self.send_response(HTTPStatus.OK)
                self.send_header("Content-Type", "text/html; charset=utf-8")
                self.end_headers()
                self.wfile.write(HTML_PAGE.encode("utf-8"))
                return

            if parsed.path == "/api/sessions":
                query = urllib.parse.parse_qs(parsed.query)
                days = int(query.get("days", [str(default_days)])[0])
                agent = query.get("agent", [""])[0]
                needs_attention = query.get("needs_attention", ["0"])[0] == "1"
                review_only = query.get("review_only", ["0"])[0] == "1"
                needle = query.get("q", [""])[0]
                limit = int(query.get("limit", ["200"])[0])
                sort = query.get("sort", ["attention"])[0]
                with connect_db(db_path) as conn:
                    sessions = query_sessions(conn, days, agent, needs_attention, review_only, needle, limit, sort)
                self.send_json({"sessions": sessions})
                return

            if parsed.path == "/api/session":
                query = urllib.parse.parse_qs(parsed.query)
                session_key = query.get("session_key", [""])[0]
                with connect_db(db_path) as conn:
                    payload = query_session_detail(conn, session_key)
                if payload is None:
                    self.send_error(HTTPStatus.NOT_FOUND, "Session not found")
                    return
                self.send_json(payload)
                return

            if parsed.path == "/api/raw":
                query = urllib.parse.parse_qs(parsed.query)
                session_key = query.get("session_key", [""])[0]
                with connect_db(db_path) as conn:
                    row = conn.execute("SELECT source_path FROM sessions WHERE session_key = ?", (session_key,)).fetchone()
                if row is None:
                    self.send_error(HTTPStatus.NOT_FOUND, "Session not found")
                    return
                source_path = Path(row["source_path"])
                if not source_path.exists():
                    self.send_error(HTTPStatus.NOT_FOUND, "Transcript file missing")
                    return
                content = source_path.read_text(encoding="utf-8", errors="replace")
                self.send_response(HTTPStatus.OK)
                self.send_header("Content-Type", "text/plain; charset=utf-8")
                self.end_headers()
                self.wfile.write(content.encode("utf-8"))
                return

            self.send_error(HTTPStatus.NOT_FOUND, "Not found")

        def do_POST(self) -> None:
            parsed = urllib.parse.urlparse(self.path)
            if parsed.path not in {"/api/review-later", "/api/hide-session"}:
                self.send_error(HTTPStatus.NOT_FOUND, "Not found")
                return

            try:
                length = int(self.headers.get("Content-Length", "0"))
                payload = json.loads(self.rfile.read(length) or b"{}")
            except (ValueError, json.JSONDecodeError):
                self.send_error(HTTPStatus.BAD_REQUEST, "Invalid JSON body")
                return

            session_key = str(payload.get("session_key", ""))
            with connect_db(db_path) as conn:
                if parsed.path == "/api/review-later":
                    review_later = bool(payload.get("review_later"))
                    updated = set_review_later(conn, session_key, review_later)
                    if not updated:
                        self.send_error(HTTPStatus.NOT_FOUND, "Session not found")
                        return
                    self.send_json({"session_key": session_key, "review_later": review_later})
                    return

                hidden = hide_session(conn, session_key)
                if not hidden:
                    self.send_error(HTTPStatus.NOT_FOUND, "Session not found")
                    return
                self.send_json({"session_key": session_key, "hidden": True})

        def log_message(self, format: str, *args: Any) -> None:
            return

        def send_json(self, payload: dict[str, Any]) -> None:
            encoded = json.dumps(payload).encode("utf-8")
            self.send_response(HTTPStatus.OK)
            self.send_header("Content-Type", "application/json; charset=utf-8")
            self.send_header("Content-Length", str(len(encoded)))
            self.end_headers()
            self.wfile.write(encoded)

    return Handler


def serve(db_path: Path, host: str, port: int, days: int, open_browser: bool) -> None:
    server = ThreadingHTTPServer((host, port), make_handler(db_path, days))
    url = f"http://{host}:{port}/"
    print(f"Serving Agent Chat Audit at {url}")
    if open_browser:
        webbrowser.open(url)
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nStopping server.")


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--db-path", default=str(DEFAULT_DB_PATH), help="SQLite index path")
    parser.add_argument(
        "--root",
        action="append",
        default=[],
        help="Override an agent home directory, e.g. --root claude=/tmp/claude",
    )

    subparsers = parser.add_subparsers(dest="command", required=True)

    ingest_parser = subparsers.add_parser("ingest", help="Index transcript files into SQLite")
    ingest_parser.add_argument("--days", type=int, default=DEFAULT_DAYS, help="Only index files modified in the last N days")
    ingest_parser.add_argument("--all", action="store_true", help="Index all discovered transcript files")
    ingest_parser.add_argument("--verbose", action="store_true", help="Print every indexed file")

    serve_parser = subparsers.add_parser("serve", help="Serve the browser UI")
    serve_parser.add_argument("--host", default="127.0.0.1", help="Bind host")
    serve_parser.add_argument("--port", type=int, default=DEFAULT_PORT, help="Bind port")
    serve_parser.add_argument("--days", type=int, default=DEFAULT_DAYS, help="Default UI day range")
    serve_parser.add_argument("--open", action="store_true", help="Open the browser automatically")

    refresh_parser = subparsers.add_parser("refresh", help="Run ingest, then serve")
    refresh_parser.add_argument("--days", type=int, default=DEFAULT_DAYS, help="Only index files modified in the last N days")
    refresh_parser.add_argument("--all", action="store_true", help="Index all discovered transcript files")
    refresh_parser.add_argument("--verbose", action="store_true", help="Print every indexed file")
    refresh_parser.add_argument("--host", default="127.0.0.1", help="Bind host")
    refresh_parser.add_argument("--port", type=int, default=DEFAULT_PORT, help="Bind port")
    refresh_parser.add_argument("--ui-days", type=int, default=DEFAULT_DAYS, help="Default UI day range")
    refresh_parser.add_argument("--open", action="store_true", help="Open the browser automatically")

    return parser.parse_args(argv)


def main(argv: list[str] | None = None) -> int:
    args = parse_args(argv or sys.argv[1:])
    db_path = Path(args.db_path).expanduser()
    roots = parse_roots(args.root)

    if args.command == "ingest":
        summary = ingest(db_path, roots, days=None if args.all else args.days, verbose=args.verbose)
        print(json.dumps(summary, indent=2, sort_keys=True))
        return 0

    if args.command == "serve":
        serve(db_path, args.host, args.port, args.days, args.open)
        return 0

    if args.command == "refresh":
        summary = ingest(db_path, roots, days=None if args.all else args.days, verbose=args.verbose)
        print(json.dumps(summary, indent=2, sort_keys=True))
        serve(db_path, args.host, args.port, args.ui_days, args.open)
        return 0

    raise AssertionError(f"Unhandled command: {args.command}")


if __name__ == "__main__":
    raise SystemExit(main())
