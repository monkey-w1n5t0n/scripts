#!/usr/bin/env bash
# List repos in ~/src that are forks from other people

SRC_DIR="$HOME/src"
GT_IGNORE="$HOME/src/.gt-ignore"

for repo_dir in "$SRC_DIR"/*; do
	[[ ! -d "$repo_dir" ]] && continue
	[[ ! -d "$repo_dir/.git" ]] && continue

	repo_name=$(basename "$repo_dir")
	repo_full_name=$(cd "$repo_dir" && git remote get-url origin 2>/dev/null | sed -E 's|.*[:/]([^/]+/[^/]+)\.git$|\1|' || echo "")

	# Skip if in ignore list
	if [[ -f "$GT_IGNORE" ]]; then
		if grep -qx "$repo_name" "$GT_IGNORE" || grep -qx "$repo_full_name" "$GT_IGNORE"; then
			continue
		fi
	fi

	cd "$repo_dir" || continue

	# Check if it's a fork by checking for upstream remote OR via GitHub CLI
	if git remote | grep -q "upstream"; then
		echo "$repo_name"
	elif [[ -n "$repo_full_name" ]]; then
		# Check via GitHub API if it's a fork
		if gh repo view "$repo_full_name" --json isFork --jq '.isFork' 2>/dev/null | grep -q "true"; then
			echo "$repo_name"
		fi
	fi
done
